# ---------- App runtime ----------
NODE_ENV=development
PORT=3000

# ---------- Database ----------
DATABASE_URL=postgresql://user:password@localhost:5432/oneto?schema=public

# ---------- Auth ----------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=generate-with-openssl-rand-base64-32
JWT_EXPIRES_IN=15m

# ---------- Email (OTP delivery via Resend) ----------
# For dev, leave blank — FakeOtpProvider logs to console
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_ADDRESS=oneto <noreply@getoneto.com>

# ---------- Payments (Korapay) ----------
KORAPAY_PUBLIC_KEY=pk_test_xxx
KORAPAY_SECRET_KEY=sk_test_xxx
KORAPAY_BASE_URL=https://api.korapay.com/merchant/api/v1

# ---------- Cashout payouts ----------
# korapay_api (default) | manual
CASHOUT_PAYOUT_MODE=korapay_api

# Optional admin notification recipients for new merchant cashout requests
ADMIN_CASHOUT_NOTIFICATION_EMAILS=admin1@example.com,admin2@example.com
