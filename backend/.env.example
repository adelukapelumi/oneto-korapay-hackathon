# Admin web CORS allowlist
# Comma-separated origins. Example:
# ADMIN_WEB_ORIGINS=https://admin.getoneto.com,https://staging-admin.getoneto.com
ADMIN_WEB_ORIGINS=

# Cashout payout mode: korapay_api (default) | manual
CASHOUT_PAYOUT_MODE=korapay_api

# Optional comma-separated admin notification recipients for new cashout requests
ADMIN_CASHOUT_NOTIFICATION_EMAILS=admin1@example.com,admin2@example.com
