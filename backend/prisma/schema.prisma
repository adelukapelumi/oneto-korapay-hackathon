generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  MERCHANT
  ADMIN
}

enum Status {
  ACTIVE
  FROZEN
  FLAGGED
  PENDING_VERIFICATION
}

enum CashoutStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum DeviceKeyStatus {
  ACTIVE
  VERIFY_ONLY
  REVOKED
}

enum OfflinePaymentResolutionStatus {
  EXPIRED_UNCLAIMED
  REJECTED
}

enum KeyRecoveryStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum KeyRecoveryRiskType {
  LOST_DEVICE
  COMPROMISED_DEVICE
}

enum KeyRecoveryReason {
  LOST_PHONE
  STOLEN_PHONE
  DAMAGED_PHONE
  APP_UNINSTALLED
  APP_DATA_CLEARED
  FACTORY_RESET
  FORGOT_PIN
  KEYPAIR_WIPED
  OTHER
}

enum TopupFeeBearer {
  STUDENT
  ONETO
  UNKNOWN
}

model User {
  id                  String        @id @default(cuid()) // Legacy fallback only. Envelope-participating users must be created with canonical "u_" IDs in service helpers.
  email               String        @unique
  phone               String?
  verifiedBalanceKobo BigInt        @default(0)
  publicKey           String?
  sequenceNumber      Int           @default(1)
  role                Role          @default(STUDENT)
  status              Status        @default(PENDING_VERIFICATION)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  ledgerEntries       LedgerEntry[]
  processedSequences ProcessedSequence[]
  deviceKeys         UserDeviceKey[]
  offlinePaymentResolutions OfflinePaymentResolution[] @relation("SenderOfflinePaymentResolutions")
  keyRecoveryRequests KeyRecoveryRequest[] @relation("UserKeyRecoveryRequests")
  reviewedKeyRecoveryRequests KeyRecoveryRequest[] @relation("ReviewedKeyRecoveryRequests")
  merchantProfile    MerchantProfile?
  cashouts           Cashout[] @relation("MerchantCashouts")
  approvedCashouts   Cashout[] @relation("AdminApprovals")

  @@index([email])
}

model UserDeviceKey {
  id          String          @id @default(cuid())
  userId      String
  publicKey   String          @unique
  status      DeviceKeyStatus
  validFrom   DateTime        @default(now())
  retiredAt   DateTime?
  verifyUntil DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user        User            @relation(fields: [userId], references: [id])
  recoveryRequests KeyRecoveryRequest[] @relation("OldKeyRecoveryRequests")

  @@index([userId, status])
  @@unique([userId, publicKey])
}

model KeyRecoveryRequest {
  id                    String              @id @default(cuid())
  userId                String
  oldKeyId              String
  requestedNewPublicKey String
  status                KeyRecoveryStatus   @default(PENDING)
  riskType              KeyRecoveryRiskType
  reason                KeyRecoveryReason
  userNotes             String?
  approximateBalanceKobo BigInt?
  lastMerchantText      String?
  lastTopupAmountKobo   BigInt?
  reviewedByUserId      String?
  reviewedAt            DateTime?
  decisionNotes         String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  user                  User                @relation("UserKeyRecoveryRequests", fields: [userId], references: [id])
  oldKey                UserDeviceKey       @relation("OldKeyRecoveryRequests", fields: [oldKeyId], references: [id])
  reviewedBy            User?               @relation("ReviewedKeyRecoveryRequests", fields: [reviewedByUserId], references: [id])

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([oldKeyId])
}

enum LedgerEntryType {
  DEBIT
  CREDIT
}

model LedgerEntry {
  id               String          @id @default(cuid())
  transactionId    String
  userId           String
  type             LedgerEntryType
  amountKobo       BigInt
  balanceAfterKobo BigInt
  description      String
  envelopeJson     Json?
  createdAt        DateTime        @default(now())

  user             User            @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@unique([transactionId, userId])
}

model PaymentTopup {
  id                 String         @id @default(cuid())
  reference          String         @unique
  userId             String
  amountKobo         BigInt
  creditedAmountKobo BigInt
  feeBearer          TopupFeeBearer @default(STUDENT)
  processorFeeKobo   BigInt?
  grossPaidKobo      BigInt?
  status             String         @default("PENDING")
  korapayResponse    Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model ProcessedSequence {
  id              String   @id @default(cuid())
  userId          String
  sequenceNumber  Int
  transactionId   String
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])

  @@unique([userId, sequenceNumber])
  @@index([userId, createdAt])
}

model OfflinePaymentResolution {
  id              String                         @id @default(cuid())
  transactionId   String                         @unique
  senderUserId    String
  recipientUserId String
  status          OfflinePaymentResolutionStatus
  reason          String
  claimDeadlineAt DateTime
  envelopeJson    Json?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  sender          User                           @relation("SenderOfflinePaymentResolutions", fields: [senderUserId], references: [id])

  @@index([senderUserId, status])
  @@index([recipientUserId, status])
  @@index([claimDeadlineAt])
}

model MerchantProfile {
  id                   String    @id @default(cuid())
  userId               String    @unique
  businessName         String
  businessAddress      String?
  cashoutBankName      String
  cashoutBankCode      String
  cashoutAccountNumber String
  cashoutAccountName   String
  verifiedAt           DateTime? // null = unverified, set once admin approves
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id])

  @@index([businessName])
}

model Cashout {
  id                   String        @id @default(cuid())
  merchantUserId       String
  amountKobo           BigInt        // Legacy compatibility: equal to grossAmountKobo for new cashouts.
  grossAmountKobo      BigInt?
  onetoFeeBps          Int           @default(250)
  onetoFeeKobo         BigInt?
  korapayPayoutFeeKobo BigInt?
  netPayoutKobo        BigInt?
  finalPayoutAmountKobo BigInt?
  status               CashoutStatus @default(PENDING)
  cashoutBankName      String
  cashoutBankCode      String
  cashoutAccountNumber String
  cashoutAccountName   String
  korapayReference     String?       @unique
  korapayResponse      Json?
  failureReason        String?
  requestedAt          DateTime      @default(now())
  approvedAt           DateTime?
  approvedByUserId     String?
  completedAt          DateTime?

  merchant             User          @relation("MerchantCashouts", fields: [merchantUserId], references: [id])
  approvedBy           User?         @relation("AdminApprovals", fields: [approvedByUserId], references: [id])

  @@index([merchantUserId, requestedAt])
  @@index([status])
}
