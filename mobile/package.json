{
  "name": "@oneto/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "./index.js",
  "scripts": {
    "prestart": "pnpm --filter @oneto/shared build",
    "start": "expo start --go",
    "prestart:dev-client": "pnpm --filter @oneto/shared build",
    "start:dev-client": "expo start --dev-client",
    "preandroid": "pnpm --filter @oneto/shared build",
    "android": "expo run:android",
    "preios": "pnpm --filter @oneto/shared build",
    "ios": "expo run:ios",
    "preweb": "pnpm --filter @oneto/shared build",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@bam.tech/react-native-app-security": "^1.0.0",
    "@expo-google-fonts/press-start-2p": "^0.4.1",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/metro-runtime": "~6.1.2",
    "@hookform/resolvers": "^3.10.0",
    "@noble/ciphers": "1.0.0",
    "@noble/hashes": "1.4.0",
    "@oneto/shared": "workspace:*",
    "@tanstack/react-query": "^5.62.7",
    "axios": "1.7.9",
    "expo": "~54.0.34",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-font": "^55.0.7",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-secure-store": "15.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "fast-text-encoding": "^1.0.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.54.2",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "13.15.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/react": "~19.1.17",
    "jest": "~29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.5.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.expo/",
      "/app/"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@noble/.*)"
    ]
  }
}
