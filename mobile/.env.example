# Required. The HTTPS URL of the oneto backend.
# For local dev pointing at the deployed backend:
#   EXPO_PUBLIC_API_URL=https://api.getoneto.com
# For local dev against a local backend over LAN, use the LAN IP, e.g.:
#   EXPO_PUBLIC_API_URL=https://192.168.1.42:3000
# Note: must be HTTPS. Plain http will be rejected by env validation.
EXPO_PUBLIC_API_URL=
